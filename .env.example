# ─── Telegram User Account (Telethon) ────────────────────────
# Lấy từ: https://my.telegram.org
TELEGRAM_API_ID=xxx
TELEGRAM_API_HASH=xxx

# Chạy: python3 setup_session.py để lấy chuỗi này
SESSION_STRING=

# ─── Telegram Bot Token ───────────────────────────────────────
# Lấy từ @BotFather → /newbot
BOT_TOKEN=xxxxx
BOT_JIRA_TOKEN=xxxxx
BOT_AGENT_TOKEN=xxxxx

# ─── Whitelist ────────────────────────────────────────────────
# User ID của bạn — nhắn @userinfobot để lấy
# Nhiều user: 123456,789012
ALLOWED_USER_IDS=xxxx

# ─── Google Gemini ────────────────────────────────────────────
# Lấy từ: https://aistudio.google.com/app/apikey (MIỄN PHÍ)
GEMINI_API_KEY=xxxx

# ─── Settings ─────────────────────────────────────────────────
GEMINI_MODEL=gemini-2.0-flash
MAX_MESSAGES=200
LANGUAGE=vi

# ─── Chat mode ────────────────────────────────────────────────
# Số lượt hội thoại tối đa lưu trong memory (1 lượt = 1 câu hỏi + 1 trả lời)
# Tăng lên nếu cần nhớ context dài hơn, giảm để tiết kiệm token
CHAT_MAX_HISTORY=20

# ─── Mention listener ─────────────────────────────────────────
# Username của bot (KHONG co @) — lay tu @BotFather
# Vi du: bot la @MySummaryBot thi dien: MySummaryBot
BOT_USERNAME=MySummaryBot

# So tin nhan lay lam context khi bot duoc mention
MENTION_CONTEXT=20

# Username Telegram CUA BAN (khong co @) — de detect khi bi tag
# Vi du: ban la @johnsmith thi dien: johnsmith
OWNER_USERNAME=your_telegram_username

# URL Jira Server (không có / ở cuối)
JIRA_BASE_URL=https://cntt.vnpt.vn/

# Personal Access Token Jira
JIRA_PAT=your_jira_pat_here

# Tắt SSL verify nếu dùng self-signed certificate
JIRA_VERIFY_SSL=true

# Personal Access Token GitLab (nếu repository yêu cầu xác thực)
GITLAB_PAT=your_gitlab_pat_here

# ─── OpenCode.ai Integration ──────────────────────────────────
# Có sử dụng Local OpenCode Server hay không (true/false)
USE_LOCAL_OPENCODE=true
# URL của Local OpenCode Server (mặc định port 4096)
OPENCODE_LOCAL_URL=http://localhost:4096

